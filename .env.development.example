# Clerk publishable key (from Clerk Dashboard → API Keys)
PLASMO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk Frontend API URL (e.g. https://clerk.yourdomain.com)
CLERK_FRONTEND_API=

# Sync Host — your web app URL that the extension syncs auth with (e.g. https://yourdomain.com)
PLASMO_PUBLIC_CLERK_SYNC_HOST=
